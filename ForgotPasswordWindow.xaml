<Window x:Class="MortuaryApp.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow"
        ResizeMode="NoResize" FontFamily="Segoe UI"
        Background="#FFFFFF" Foreground="#0F172A">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Forgot Password" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" Text="Enter your email to receive a temporary password." FontSize="12" Foreground="#64748B" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="2" Text="Email Address" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
        <Border Grid.Row="3" BorderThickness="1" BorderBrush="#D1D5DB" Background="#F9FAFB" Height="42">
            <TextBox x:Name="TxtEmail" Background="Transparent" BorderThickness="0"
                     FontSize="13" Foreground="#0F172A" VerticalAlignment="Center" Margin="12,0"
                     Text=""/>
        </Border>

        <TextBlock x:Name="TxtResult" Grid.Row="4" Text="" FontSize="12" Foreground="#16A34A" TextWrapping="Wrap" Margin="0,12,0,0" Visibility="Collapsed"/>
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnReset" Content="Send Temporary Password" Height="38" Click="BtnReset_Click" IsDefault="True" Style="{StaticResource PrimaryBtn}" Padding="20,0"/>
            <Button x:Name="BtnClose" Content="Close" Width="80" Height="38" Margin="10,0,0,0" Click="BtnClose_Click" Style="{StaticResource SecondaryBtn}"/>
        </StackPanel>
    </Grid>
</Window>
