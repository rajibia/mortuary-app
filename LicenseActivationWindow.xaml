<Window x:Class="MortuaryApp.LicenseActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Software Activation" Height="500" Width="700"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border BorderThickness="0" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0F172A">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="56" Height="56" Background="#1E293B" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Activation" FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFF"
                               TextAlignment="Center" Margin="0,16,0,2"/>
                    <TextBlock Text="Required" FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFF"
                               TextAlignment="Center" Margin="0,0,0,8"/>
                    <Rectangle Height="2" Width="36" Fill="#F59E0B" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <TextBlock Text="Please activate your" FontSize="11" Foreground="#94A3B8"
                               TextAlignment="Center"/>
                    <TextBlock Text="copy of the software" FontSize="11" Foreground="#94A3B8"
                               TextAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock Text="to continue" FontSize="11" Foreground="#94A3B8"
                               TextAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#FFFFFF">
                <StackPanel VerticalAlignment="Center" Margin="50,0">
                    <TextBlock Text="Software Activation" FontSize="22" FontWeight="SemiBold" Foreground="#0F172A"/>
                    <TextBlock Text="This software is not yet activated. Enter your license key below." FontSize="12" Foreground="#6B7280" Margin="0,4,0,24"/>

                    <Border Background="#F8FAFC" BorderThickness="1" BorderBrush="#E2E8F0" Padding="16" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Machine ID" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
                            <Border BorderThickness="1" BorderBrush="#CBD5E1" Background="#F8FAFC" Height="38">
                                <TextBox x:Name="TxtMachineId" IsReadOnly="True" FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                                         Foreground="#0F172A" Background="Transparent" BorderThickness="0"
                                         VerticalAlignment="Center" VerticalContentAlignment="Center" Margin="8,0"
                                         Text="Loading..." Cursor="IBeam" GotFocus="TxtMachineId_GotFocus"/>
                            </Border>
                            <TextBlock Text="Send this Machine ID to your software provider to receive a license key."
                                       FontSize="10" Foreground="#94A3B8" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="License Key" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
                    <Border BorderThickness="1" BorderBrush="#D1D5DB" Background="#F9FAFB" Height="42">
                        <TextBox x:Name="TxtLicenseKey" Background="Transparent" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="14" Foreground="#0F172A" VerticalAlignment="Center" Margin="12,0"
                                 materialDesign:HintAssist.Hint="Paste your license key here"/>
                    </Border>

                    <TextBlock x:Name="TxtError" Text="" FontSize="11" Foreground="#DC2626" Margin="0,8,0,0"/>

                    <Button x:Name="BtnActivate" Click="BtnActivate_Click" Height="42" Margin="0,18,0,0"
                            BorderThickness="0" Cursor="Hand" Background="#F59E0B">
                        <TextBlock Text="Activate" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                    </Button>

                    <Button Name="BtnExit" Click="BtnExit_Click" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" FontSize="11" Foreground="#6B7280" Margin="0,12,0,0" HorizontalAlignment="Center">
                        <TextBlock Text="Exit Application" TextDecorations="Underline"/>
                    </Button>

                    <TextBlock Text="Powered by Msoft Ghana" FontSize="10" Foreground="#94A3B8"
                               TextAlignment="Center" Margin="0,24,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
