<Window x:Class="MortuaryApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Msoft Mortuary Pro" Height="520" Width="800"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border BorderThickness="0" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal" Margin="0,8,10,0" ZIndex="10">
                <Button x:Name="BtnMinimize" Width="36" Height="28" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="BtnMinimize_Click">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#64748B"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="BtnClose" Width="36" Height="28" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="BtnClose_Click">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#64748B"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>

            <!-- Left: Brand Sidebar -->
            <Border Grid.Column="0" Background="#0F172A">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image x:Name="ImgLoginLogo" Width="64" Height="64" Stretch="Uniform" Visibility="Collapsed" HorizontalAlignment="Center"/>
                    <Border x:Name="LoginIconBox" Width="64" Height="64" Background="#1E293B" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE15D;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                   Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                        <TextBlock x:Name="TxtBrandName" Text="Msoft Mortuary Pro" FontSize="22" FontWeight="SemiBold" Foreground="#FFFFFF"
                                   TextAlignment="Center" Margin="0,20,0,8"/>
                    <Rectangle Height="2" Width="40" Fill="#F59E0B" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Efficient mortuary operations" FontSize="11" Foreground="#94A3B8"
                               TextAlignment="Center"/>
                    <TextBlock Text="management platform" FontSize="11" Foreground="#94A3B8"
                               TextAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Right: Login Form -->
            <Border Grid.Column="1" Background="#FFFFFF">
                <StackPanel VerticalAlignment="Center" Margin="60,0">
                    <TextBlock Text="Welcome Back" FontSize="24" FontWeight="SemiBold" Foreground="#0F172A"/>
                    <TextBlock Text="Sign in to your account to continue" FontSize="13" Foreground="#6B7280" Margin="0,4,0,32"/>

                    <TextBlock Text="Email Address" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
                    <Border BorderThickness="1" BorderBrush="#D1D5DB" Background="#F9FAFB" Height="42">
                        <TextBox x:Name="TxtEmail" Background="Transparent" BorderThickness="0"
                                 FontSize="13" Foreground="#0F172A" VerticalAlignment="Center" Margin="12,0"
                                 materialDesign:HintAssist.Hint="Enter your email address"/>
                    </Border>

                    <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,16,0,6"/>
                    <Border BorderThickness="1" BorderBrush="#D1D5DB" Background="#F9FAFB" Height="42">
                        <PasswordBox x:Name="TxtPassword" Background="Transparent" BorderThickness="0"
                                     FontSize="13" Foreground="#0F172A" VerticalAlignment="Center" Margin="12,0"
                                     materialDesign:HintAssist.Hint="Enter your password"/>
                    </Border>

                    <TextBlock x:Name="TxtError" Text="" FontSize="11" Foreground="#DC2626" Margin="0,8,0,0"/>

                    <Button x:Name="BtnLogin" Click="BtnLogin_Click" Height="42" Margin="0,20,0,0"
                            BorderThickness="0" Cursor="Hand" Background="#F59E0B">
                        <TextBlock Text="Sign In" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                    </Button>

                    <Button Name="BtnForgotPassword" Click="BtnForgotPassword_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            FontSize="11" Foreground="#6B7280" Margin="0,14,0,0"
                            HorizontalAlignment="Center">
                        <TextBlock Text="Forgot your password?" TextDecorations="Underline"/>
                    </Button>

                    <TextBlock Text="Powered by Msoft Ghana" FontSize="10" Foreground="#94A3B8"
                               TextAlignment="Center" Margin="0,30,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
