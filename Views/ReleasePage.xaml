<UserControl x:Class="MortuaryApp.Views.ReleasePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MortuaryApp.Controls"
             Background="{DynamicResource ContentBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{DynamicResource Card}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Initiate Release" Style="{StaticResource ModernSectionTitle}" Margin="0,0,0,10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Body:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CboBody" Style="{DynamicResource ModernComboBox}" DisplayMemberPath="DeceasedName" SelectionChanged="CboBody_SelectionChanged" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Released To:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtReleasedTo" Style="{DynamicResource ModernTextBox}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Relationship:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtRelationship" Style="{DynamicResource ModernTextBox}" />
                        <TextBlock Grid.Row="2" Grid.Column="3" Text="ID Number:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="4" x:Name="TxtIdNumber" Style="{DynamicResource ModernTextBox}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Phone:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" />
                        <controls:PhoneInput x:Name="TxtPhone" Grid.Row="4" Grid.Column="1" Height="34"/>
                        <TextBlock Grid.Row="4" Grid.Column="3" Text="Notes:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="4" Grid.Column="4" x:Name="TxtNotes" Style="{DynamicResource ModernTextBox}" />
                    </Grid>
                </StackPanel>
            </Border>
            <Border Grid.Row="1" x:Name="BillsPanel" Style="{DynamicResource Card}" Margin="0,0,0,10" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Bills" Style="{StaticResource ModernSectionTitle}" Margin="0,0,0,4" />
                    <WrapPanel x:Name="BillsSummary" Margin="0,0,0,8" />
                    <DataGrid x:Name="DgBills" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}" Height="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="70" />
                            <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat={}{0:N2}}" Width="70" />
                            <DataGridTextColumn Header="Balance" Binding="{Binding Balance, StringFormat={}{0:N2}}" Width="70" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="TxtBillsStatus" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0" />
                    <Button x:Name="BtnInitiate" MinWidth="120" Height="34" Margin="0,10,0,0" HorizontalAlignment="Right" Style="{DynamicResource PrimaryBtn}" Click="BtnInitiate_Click">
                        <TextBlock Text="Initiate Release" VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Border>
            <TabControl Grid.Row="2" Style="{DynamicResource ModernTabControl}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}"/>
                </TabControl.Resources>
                <TabItem Header="Pending Approvals">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="BtnApprove" MinWidth="100" Height="34" Style="{DynamicResource PrimaryBtn}" Click="BtnApprove_Click">
                                <TextBlock Text="Approve Selected" VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>
                        <DataGrid Grid.Row="1" x:Name="DgPending" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Body" Binding="{Binding Body.DeceasedName}" Width="120" />
                                <DataGridTextColumn Header="Released To" Binding="{Binding ReleasedTo}" Width="*" />
                                <DataGridTextColumn Header="Relationship" Binding="{Binding Relationship}" Width="100" />
                                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70" />
                                <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="Completed">
                    <Grid Margin="0,10,0,0">
                        <DataGrid x:Name="DgApproved" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Body" Binding="{Binding Body.DeceasedName}" Width="120" />
                                <DataGridTextColumn Header="Released To" Binding="{Binding ReleasedTo}" Width="*" />
                                <DataGridTextColumn Header="Released At" Binding="{Binding ReleasedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </ScrollViewer>
</UserControl>
