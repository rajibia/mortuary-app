<UserControl x:Class="MortuaryApp.Views.BillingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBgBrush}">
    <Grid Margin="15">
        <TabControl Style="{DynamicResource ModernTabControl}">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}"/>
            </TabControl.Resources>
            <TabItem Header="Billable Bodies">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0" x:Name="DgBillableBodies" Style="{DynamicResource ModernDataGrid}" IsReadOnly="True" AutoGenerateColumns="False" SelectionChanged="DgBillableBodies_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mortuary #" Binding="{Binding MortuaryNumber}" Width="110" />
                            <DataGridTextColumn Header="Deceased Name" Binding="{Binding DeceasedName}" Width="*" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountToBePaid, StringFormat={}{0:N2}}" Width="70" />
                            <DataGridTextColumn Header="Deposit" Binding="{Binding DepositAmount, StringFormat={}{0:N2}}" Width="70" />
                            <DataGridTextColumn Header="Rate" Binding="{Binding BillingRate, StringFormat={}{0:N2}}" Width="70" />
                            <DataGridTextColumn Header="Type" Binding="{Binding BillingType}" Width="60" />
                            <DataGridTextColumn Header="Start Date" Binding="{Binding BillingStartAt, StringFormat={}{0:yyyy-MM-dd}}" Width="90" />
                            <DataGridTextColumn Header="Start Time" Binding="{Binding BillingStartAt, StringFormat={}{0:h:mm tt}}" Width="75" />
                             <DataGridTextColumn Header="Net Balance" Binding="{Binding NetBalance, StringFormat={}{0:N2}}" Width="80" />
                             <DataGridTextColumn Header="Payment Status" Binding="{Binding PaymentStatus}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="1" x:Name="PaymentPanel" Style="{DynamicResource Card}" Visibility="Collapsed" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                                <TextBlock x:Name="TxtSelectedName" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0" />
                                <TextBlock x:Name="TxtSelectedBalance" FontSize="14" FontWeight="SemiBold" Foreground="#DC2626" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="Pay Amount:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox Grid.Column="3" x:Name="TxtPayAmount" Style="{DynamicResource ModernTextBox}" Text="" VerticalAlignment="Center" />
                            <Button Grid.Column="4" x:Name="BtnPaySelected" MinWidth="110" Height="34" Style="{DynamicResource PrimaryBtn}" Margin="15,0,0,0" Click="BtnPaySelected_Click">
                                <TextBlock Text="Pay Selected" VerticalAlignment="Center" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Charges">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>
                        <Border Style="{DynamicResource Card}" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" /><ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" /><ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30" /><RowDefinition Height="30" /><RowDefinition Height="30" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Body:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CboBody" Style="{DynamicResource ModernComboBox}" DisplayMemberPath="DeceasedName" Margin="3" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Description:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" Margin="10,0,0,0" />
                                <TextBox Grid.Row="0" Grid.Column="3" x:Name="TxtDescription" Style="{DynamicResource ModernTextBox}" Margin="3" />
                                <Button Grid.Row="0" Grid.Column="4" x:Name="BtnAddCharge" MinWidth="110" Style="{DynamicResource PrimaryBtn}" Margin="10,0,0,0" Click="BtnAddCharge_Click">
                                    <TextBlock Text="+ Add Charge" VerticalAlignment="Center" />
                                </Button>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Amount:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtAmount" Style="{DynamicResource ModernTextBox}" Margin="3" Text="0" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Charge Type:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" Margin="10,0,0,0" />
                                <ComboBox Grid.Row="1" Grid.Column="3" x:Name="CboChargeType" Style="{DynamicResource ModernComboBox}" DisplayMemberPath="Name" Margin="3" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Notes:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" />
                                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" x:Name="TxtNotes" Style="{DynamicResource ModernTextBox}" Margin="3" />
                            </Grid>
                        </Border>
                        <DataGrid x:Name="DgCharges" Style="{DynamicResource ModernDataGrid}" IsReadOnly="True" AutoGenerateColumns="False" Height="220" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Body" Binding="{Binding Body.DeceasedName}" Width="120" />
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="80" />
                                <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat={}{0:N2}}" Width="80" />
                                <DataGridTextColumn Header="Balance" Binding="{Binding Balance, StringFormat={}{0:N2}}" Width="80" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button x:Name="BtnRecordPayment" MinWidth="130" Style="{DynamicResource PrimaryBtn}" HorizontalAlignment="Left" Click="BtnRecordPayment_Click">
                            <TextBlock Text="Record Payment" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Charge Types">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>
                        <DataGrid x:Name="DgChargeTypes" Style="{DynamicResource ModernDataGrid}" IsReadOnly="True" AutoGenerateColumns="False" Height="200" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="80" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Default Amount" Binding="{Binding DefaultAmount, StringFormat={}{0:N2}}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button x:Name="BtnAddChargeType" MinWidth="130" Style="{DynamicResource PrimaryBtn}" HorizontalAlignment="Left" Click="BtnAddChargeType_Click">
                            <TextBlock Text="+ New Charge Type" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Paid / Released">
                <DataGrid x:Name="DgPaidBodies" Style="{DynamicResource ModernDataGrid}" IsReadOnly="True" AutoGenerateColumns="False" Margin="0,10,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mortuary #" Binding="{Binding MortuaryNumber}" Width="100" />
                        <DataGridTextColumn Header="Deceased Name" Binding="{Binding DeceasedName}" Width="*" />
                        <DataGridTextColumn Header="Amount" Binding="{Binding AmountToBePaid, StringFormat={}{0:N2}}" Width="70" />
                        <DataGridTextColumn Header="Deposit" Binding="{Binding DepositAmount, StringFormat={}{0:N2}}" Width="70" />
                        <DataGridTextColumn Header="Total Paid" Binding="{Binding TotalPaid, StringFormat={}{0:N2}}" Width="80" />
                        <DataGridTextColumn Header="Released To" Binding="{Binding ReleasedTo}" Width="120" />
                        <DataGridTextColumn Header="Released At" Binding="{Binding ReleasedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="120" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
