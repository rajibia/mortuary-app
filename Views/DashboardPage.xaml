<UserControl x:Class="MortuaryApp.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{DynamicResource ContentBgBrush}">
    <Grid>
        <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- KPI Grid (4 cards) -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource StatCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bodies in Storage" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="TxtInStorage" Style="{StaticResource StatValue}" Margin="0,6,0,0"/>
                                <TextBlock x:Name="TxtStorageUsage" Style="{StaticResource ModernCaptionText}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10" Background="#EEF2FF" VerticalAlignment="Top">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#6366F1"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Released Today" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="TxtReleasedToday" Style="{StaticResource StatValue}" Margin="0,6,0,0"/>
                                <TextBlock x:Name="TxtWeekReleases" Style="{StaticResource ModernCaptionText}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10" Background="#ECFDF5" VerticalAlignment="Top">
                                <TextBlock Text="&#xE7B1;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#059669"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource StatCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Pending Release" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="TxtPendingRelease" Style="{StaticResource StatValue}" Margin="0,6,0,0"/>
                                <TextBlock x:Name="TxtPendingAmount" Style="{StaticResource ModernCaptionText}" Foreground="#DC2626" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10" Background="#FEF2F2" VerticalAlignment="Top">
                                <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#DC2626"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="6" Style="{StaticResource StatCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Cold Room Occupancy" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="TxtOccupancy" Style="{StaticResource StatValue}" Margin="0,6,0,0"/>
                                <Border Width="6" Height="6" CornerRadius="3" Background="#059669" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10" Background="#FFF7ED" VerticalAlignment="Top">
                                <TextBlock Text="&#xE619;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#F59E0B"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Charts Row -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="MONTHLY ADMISSIONS" Style="{StaticResource SectionHeader}"/>
                            <lvc:CartesianChart Name="AdmissionsChart" Height="240"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="COLD ROOM OCCUPANCY" Style="{StaticResource SectionHeader}"/>
                            <lvc:PieChart Name="OccupancyChart" Height="240"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Recent Admissions -->
                <Border Style="{StaticResource Card}" Padding="0" CornerRadius="12">
                    <StackPanel>
                        <Grid Margin="20,16,20,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Recent Admissions" Style="{StaticResource ModernSectionTitle}"/>
                                <TextBlock Text="Latest body admissions to the mortuary" Style="{StaticResource ModernCaptionText}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryBtn}" Content="View All" Height="34" Padding="16,0" FontSize="12"/>
                        </Grid>
                        <Border Height="1" Background="#E2E8F0"/>
                        <DataGrid x:Name="DgRecentAdmissions" Style="{StaticResource ModernDataGrid}" Height="220"
                                  BorderThickness="0" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding DeceasedName}" Width="*"/>
                                <DataGridTextColumn Header="Date Admitted" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130"/>
                                <DataGridTextColumn Header="Storage Slot" Binding="{Binding StorageLocationId}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>