<UserControl x:Class="MortuaryApp.Views.CremationsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBgBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{DynamicResource Card}" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Body:" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" x:Name="CboBody" Style="{DynamicResource ModernComboBox}" DisplayMemberPath="DeceasedName" />
                <TextBlock Grid.Column="3" Text="Auth Doc:" VerticalAlignment="Center" />
                <TextBox Grid.Column="4" x:Name="TxtAuthDoc" Style="{DynamicResource ModernTextBox}" />
                <Button Grid.Column="5" x:Name="BtnSchedule" MinWidth="100" Margin="10,0,0,0" Style="{DynamicResource PrimaryBtn}" Click="BtnSchedule_Click">
                    <TextBlock Text="Schedule" VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnComplete" MinWidth="100" Height="34" Style="{DynamicResource PrimaryBtn}" Margin="0,0,10,0" Click="BtnComplete_Click">
                <TextBlock Text="Complete" />
            </Button>
            <Button x:Name="BtnRefresh" MinWidth="100" Height="34" Style="{DynamicResource SecondaryBtn}" Click="BtnRefresh_Click">
                <TextBlock Text="Refresh" VerticalAlignment="Center" />
            </Button>
        </StackPanel>
        <DataGrid Grid.Row="2" x:Name="DgCremations" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Body" Binding="{Binding Body.DeceasedName}" Width="120" />
                <DataGridTextColumn Header="Scheduled" Binding="{Binding ScheduledAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                <DataGridTextColumn Header="Auth Document" Binding="{Binding AuthorizationDocument}" Width="*" />
                <DataGridTextColumn Header="Cremated At" Binding="{Binding CrematedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130" />
                <DataGridTextColumn Header="Ashes Disposition" Binding="{Binding AshesDisposition}" Width="120" />
                <DataGridTextColumn Header="Collected By" Binding="{Binding AshesCollectedBy}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
