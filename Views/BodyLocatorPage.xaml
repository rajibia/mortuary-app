<UserControl x:Class="MortuaryApp.Views.BodyLocatorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBgBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{DynamicResource Card}" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="TxtSearch" Width="250" Margin="0,0,10,0" Style="{DynamicResource ModernTextBox}" />
                <Button x:Name="BtnSearch" Margin="0,0,10,0" Style="{DynamicResource PrimaryBtn}" Click="BtnSearch_Click">
                    <TextBlock Text="Search" VerticalAlignment="Center" />
                </Button>
                <Button x:Name="BtnClear" Style="{DynamicResource SecondaryBtn}" Click="BtnClear_Click">
                    <TextBlock Text="Clear" VerticalAlignment="Center" />
                </Button>
            </StackPanel>
        </Border>
        <DataGrid Grid.Row="1" x:Name="DgResults" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mortuary #" Binding="{Binding MortuaryNumber}" Width="110" />
                <DataGridTextColumn Header="Deceased Name" Binding="{Binding DeceasedName}" Width="*" />
                <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="90" />
                <DataGridTextColumn Header="Location" Binding="{Binding StorageLocation.DisplayName}" Width="130" />
                <DataGridTextColumn Header="Date of Birth" Binding="{Binding DateOfBirth, StringFormat={}{0:yyyy-MM-dd}}" Width="100" />
                <DataGridTextColumn Header="Admitted" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130" />
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="2" x:Name="DetailsCard" Style="{DynamicResource Card}" Visibility="Collapsed" Margin="0,10,0,0" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="MORTUARY #" Style="{StaticResource ModernMutedText}" />
                    <TextBlock x:Name="TblMortNo" Style="{StaticResource ModernBodyText}" FontWeight="SemiBold" Margin="0,2,0,12" />
                    <TextBlock Text="DECEASED NAME" Style="{StaticResource ModernMutedText}" />
                    <TextBlock x:Name="TblName" Style="{StaticResource ModernBodyText}" FontWeight="SemiBold" Margin="0,2,0,12" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="STATUS" Style="{StaticResource ModernMutedText}" />
                    <TextBlock x:Name="TblStatus" Style="{StaticResource ModernBodyText}" FontWeight="SemiBold" Margin="0,2,0,12" />
                    <TextBlock Text="LOCATION" Style="{StaticResource ModernMutedText}" />
                    <TextBlock x:Name="TblLocation" Style="{StaticResource ModernBodyText}" FontWeight="SemiBold" Margin="0,2,0,12" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="NEXT OF KIN" Style="{StaticResource ModernMutedText}" />
                    <TextBlock x:Name="TblKin" Style="{StaticResource ModernBodyText}" FontWeight="SemiBold" Margin="0,2,0,12" />
                    <TextBlock Text="BILLING" Style="{StaticResource ModernMutedText}" />
                    <TextBlock x:Name="TblCharges" Style="{StaticResource ModernBodyText}" FontWeight="SemiBold" Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
