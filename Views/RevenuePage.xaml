<UserControl x:Class="MortuaryApp.Views.RevenuePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource ContentBgBrush}">
    <Grid>
        <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Revenue Overview" Style="{StaticResource ModernPageTitle}" />
                    <TextBlock Text="Track your monthly income and financial performance" Style="{StaticResource ModernBodyText}" Margin="0,2,0,0" />
                </StackPanel>

                <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrushTheme}" BorderThickness="1" Padding="0">
                    <StackPanel>
                        <DataGrid x:Name="DgMonthlyIncome" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}" Margin="0,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="MONTH" Binding="{Binding Month}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="14,10"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="TOTAL (GHS)" Binding="{Binding Total, StringFormat=N2}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="14,10"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
