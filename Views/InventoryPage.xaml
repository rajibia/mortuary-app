<UserControl x:Class="MortuaryApp.Views.InventoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBgBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{DynamicResource Card}" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Add Inventory Item" Style="{DynamicResource SectionHeader}" Margin="0,0,0,10" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Item Name" Style="{StaticResource ModernFormLabel}" />
                        <TextBox x:Name="TxtName" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernTextBox}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SKU" Style="{StaticResource ModernFormLabel}" />
                        <TextBox x:Name="TxtSku" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernTextBox}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Category" Style="{StaticResource ModernFormLabel}" />
                        <ComboBox x:Name="CboCategory" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernComboBox}" IsEditable="True" />
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Quantity" Style="{StaticResource ModernFormLabel}" />
                        <TextBox x:Name="TxtQty" Text="0" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernTextBox}" />
                    </StackPanel>
                    <Button Grid.Column="7" x:Name="BtnAddItem" Height="34" Margin="10,22,0,0" Style="{DynamicResource PrimaryBtn}" Click="BtnAddItem_Click">
                        <TextBlock Text="+ Add Item" VerticalAlignment="Center" />
                    </Button>
                </Grid>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Unit:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox x:Name="CboUnit" Width="80" Height="30" Style="{DynamicResource ModernComboBox}" IsEditable="True" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnAdjust" MinWidth="100" Height="34" Style="{DynamicResource PrimaryBtn}" Click="BtnAdjust_Click">
                <TextBlock Text="Adjust Stock" VerticalAlignment="Center" />
            </Button>
        </StackPanel>
        <DataGrid Grid.Row="2" x:Name="DgInventory" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="100" />
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="80" />
                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
