<UserControl x:Class="MortuaryApp.Views.TemperaturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBgBrush}">
    <Grid Margin="15">
        <TabControl Style="{DynamicResource ModernTabControl}">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}"/>
            </TabControl.Resources>
            <TabItem Header="Temperature Logs">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{DynamicResource Card}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Log Temperature" Style="{DynamicResource SectionHeader}" Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Location:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" x:Name="CboLocation" Style="{DynamicResource ModernComboBox}" DisplayMemberPath="DisplayName" />
                                <TextBlock Grid.Column="3" Text="Temp (C):" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="4" x:Name="TxtTemp" Style="{DynamicResource ModernTextBox}" />
                                <Button Grid.Column="5" x:Name="BtnLog" MinWidth="100" Margin="10,0,0,0" Style="{DynamicResource PrimaryBtn}" Click="BtnLog_Click">
                                    <TextBlock Text="Log" VerticalAlignment="Center" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <DataGrid Grid.Row="1" x:Name="DgTemps" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Location" Binding="{Binding StorageLocation.DisplayName}" Width="120" />
                            <DataGridTextColumn Header="Temperature (C)" Binding="{Binding Temperature, StringFormat={}{0:N1}}" Width="100" />
                            <DataGridTextColumn Header="Recorded At" Binding="{Binding RecordedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Alerts">
                <Grid Margin="0,10,0,0">
                    <DataGrid x:Name="DgAlerts" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Location" Binding="{Binding StorageLocation.DisplayName}" Width="120" />
                            <DataGridTextColumn Header="Temperature (C)" Binding="{Binding Temperature, StringFormat={}{0:N1}}" Width="100" />
                            <DataGridTextColumn Header="Recorded At" Binding="{Binding RecordedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
