<UserControl x:Class="MortuaryApp.Views.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource ContentBgBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Reports" Style="{StaticResource ModernPageTitle}" />
            <TextBlock Text="Select a report type to generate" Style="{StaticResource ModernBodyText}" Margin="0,2,0,0" />
        </StackPanel>
        <ScrollViewer Grid.Row="1" x:Name="CardsPanel" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="CardsContainer" />
        </ScrollViewer>
        <Border Grid.Row="1" x:Name="DetailPanel" Style="{DynamicResource Card}" Visibility="Collapsed" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <Button x:Name="BtnBack" MinWidth="80" Height="34" Style="{DynamicResource SecondaryBtn}" Margin="0,0,15,0" Click="BtnBack_Click">
                        <TextBlock Text="Back" VerticalAlignment="Center" />
                    </Button>
                    <TextBlock x:Name="TxtDetailTitle" Text="Report" Style="{StaticResource ModernSectionTitle}" VerticalAlignment="Center" Margin="0,0,15,0" />
                    <TextBlock Text="From:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" Margin="15,0,6,0" />
                    <DatePicker x:Name="DpFrom" Width="130" Style="{DynamicResource ModernDatePicker}" VerticalAlignment="Center" />
                    <TextBlock Text="To:" Style="{StaticResource ModernFormLabel}" VerticalAlignment="Center" Margin="10,0,6,0" />
                    <DatePicker x:Name="DpTo" Width="130" Style="{DynamicResource ModernDatePicker}" VerticalAlignment="Center" />
                    <Button x:Name="BtnGenerate" MinWidth="120" Height="34" Style="{DynamicResource PrimaryBtn}" Margin="15,0,0,0" Click="BtnGenerate_Click">
                        <TextBlock Text="Generate" VerticalAlignment="Center" />
                    </Button>
                    <Button x:Name="BtnExportCsv" MinWidth="60" Height="34" Style="{DynamicResource SecondaryBtn}" Margin="10,0,0,0" Click="BtnExportCsv_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDelimited" Width="14" Height="14" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="CSV" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnExportPdf" MinWidth="60" Height="34" Style="{DynamicResource SecondaryBtn}" Margin="10,0,0,0" Click="BtnExportPdf_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FilePdfBox" Width="14" Height="14" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="PDF" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnPrint" MinWidth="60" Height="34" Style="{DynamicResource SecondaryBtn}" Margin="10,0,0,0" Click="BtnPrint_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Printer" Width="14" Height="14" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Print" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <DataGrid Grid.Row="2" x:Name="DgReport" AutoGenerateColumns="True" Style="{DynamicResource ModernDataGrid}" IsReadOnly="True" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
