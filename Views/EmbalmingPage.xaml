<UserControl x:Class="MortuaryApp.Views.EmbalmingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBgBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="BtnNewEmbalming" MinWidth="140" Height="34" Style="{DynamicResource PrimaryBtn}" Margin="0,0,10,0" Click="BtnNewEmbalming_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+ New Embalming" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button x:Name="BtnStartProcedure" MinWidth="120" Height="34" Style="{DynamicResource SecondaryBtn}" Margin="0,0,10,0" Click="BtnStartProcedure_Click">
                <TextBlock Text="Start Procedure" />
            </Button>
            <Button x:Name="BtnComplete" MinWidth="100" Height="34" Style="{DynamicResource PrimaryBtn}" Margin="0,0,10,0" Click="BtnComplete_Click">
                <TextBlock Text="Complete" />
            </Button>
            <Button x:Name="BtnRefresh" MinWidth="100" Height="34" Style="{DynamicResource SecondaryBtn}" Click="BtnRefresh_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Refresh" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
        <TabControl Grid.Row="1" Style="{DynamicResource ModernTabControl}">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}"/>
            </TabControl.Resources>
            <TabItem Header="Active / Pending">
                <Grid Margin="0,10,0,0">
                    <DataGrid x:Name="DgEmbalming" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Body" Binding="{Binding Body.DeceasedName}" Width="120" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="Started At" Binding="{Binding StartedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Completed">
                <Grid Margin="0,10,0,0">
                    <DataGrid x:Name="DgOldEmbalming" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Body" Binding="{Binding Body.DeceasedName}" Width="120" />
                            <DataGridTextColumn Header="Completed At" Binding="{Binding CompletedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
