<Window x:Class="MortuaryApp.Views.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment Receipt" Height="800" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Border x:Name="ReceiptPanel" Background="White" Width="460" Margin="20,20,20,10" Padding="35,30" BorderBrush="#D0D0D0" BorderThickness="1" Effect="{x:Null}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" x:Name="LogoBorder" Width="65" Height="65" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,15,0" Visibility="Collapsed">
                            <Image x:Name="ImgLogo" Width="55" Height="55" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtOrgName" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E" TextWrapping="NoWrap" />
                            <TextBlock x:Name="TxtAddress" FontSize="10.5" Foreground="#666666" TextWrapping="Wrap" Margin="0,2,0,0" />
                            <WrapPanel Margin="0,2,0,0">
                                <TextBlock x:Name="TxtPhone" FontSize="10.5" Foreground="#666666" />
                            </WrapPanel>
                            <TextBlock x:Name="TxtEmail" FontSize="10.5" Foreground="#666666" Margin="0,1,0,0" />
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1.5" Fill="#1A1A2E" Margin="0,18,0,0" Opacity="0.15" />
                    <TextBlock Text="PAYMENT RECEIPT" FontSize="16" FontWeight="Bold" Foreground="#1A1A2E" HorizontalAlignment="Center" Margin="0,10,0,5" />
                    <Rectangle Height="1.5" Fill="#1A1A2E" Opacity="0.15" />
                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22" />
                            <RowDefinition Height="22" />
                            <RowDefinition Height="22" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Receipt #:" FontSize="11" Foreground="#888888" />
                        <TextBlock x:Name="TxtReceiptNo" Grid.Row="0" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="#333333" TextAlignment="Right" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Date/Time:" FontSize="11" Foreground="#888888" />
                        <TextBlock x:Name="TxtDate" Grid.Row="1" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="#333333" TextAlignment="Right" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Cashier:" FontSize="11" Foreground="#888888" />
                        <TextBlock x:Name="TxtCashier" Grid.Row="2" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="#333333" TextAlignment="Right" />
                    </Grid>
                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,12,0,12" />
                    <TextBlock Text="DECEASED INFORMATION" FontSize="10" FontWeight="Bold" Foreground="#888888" />
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22" />
                            <RowDefinition Height="22" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mortuary #:" FontSize="11" Foreground="#888888" />
                        <TextBlock x:Name="TxtMortuaryNo" Grid.Row="0" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="#333333" TextAlignment="Right" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Deceased:" FontSize="11" Foreground="#888888" />
                        <TextBlock x:Name="TxtDeceased" Grid.Row="1" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="#333333" TextAlignment="Right" />
                    </Grid>
                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,12,0,12" />
                    <TextBlock Text="CHARGE DETAILS" FontSize="10" FontWeight="Bold" Foreground="#888888" />
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22" />
                            <RowDefinition Height="22" />
                            <RowDefinition Height="22" />
                            <RowDefinition Height="22" />
                            <RowDefinition Height="22" />
                            <RowDefinition Height="22" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Description:" FontSize="11" Foreground="#888888" />
                        <TextBlock x:Name="TxtDescription" Grid.Row="0" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="#333333" TextAlignment="Right" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Amount Due:" FontSize="11" Foreground="#888888" />
                        <TextBlock x:Name="TxtAmount" Grid.Row="1" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="#333333" TextAlignment="Right" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Amount Paid:" FontSize="11" Foreground="#888888" />
                        <TextBlock x:Name="TxtPaidAmount" Grid.Row="2" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="#333333" TextAlignment="Right" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Change:" FontSize="11" Foreground="#888888" />
                        <TextBlock x:Name="TxtChange" Grid.Row="3" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="#059669" TextAlignment="Right" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Balance:" FontSize="11" Foreground="#888888" />
                        <TextBlock x:Name="TxtBalance" Grid.Row="4" Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="#333333" TextAlignment="Right" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Status:" FontSize="11" Foreground="#888888" />
                        <TextBlock x:Name="TxtStatus" Grid.Row="5" Grid.Column="1" FontSize="11" FontWeight="Bold" Foreground="#16A34A" TextAlignment="Right" />
                    </Grid>
                    <Rectangle Height="1.5" Fill="#1A1A2E" Margin="0,15,0,0" Opacity="0.12" />
                    <Border Background="#F8FFF8" BorderBrush="#16A34A" BorderThickness="1" Margin="0,12,0,0" Padding="15,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TOTAL PAID" FontSize="13" FontWeight="Bold" Foreground="#16A34A" VerticalAlignment="Center" />
                            <TextBlock x:Name="TxtTotalPaid" Grid.Column="1" FontSize="18" FontWeight="Bold" Foreground="#16A34A" />
                        </Grid>
                    </Border>
                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,18,0,8" />
                    <TextBlock x:Name="TxtPoweredBy" Text="Powered By Msoft Ghana (www.msoftghana.com)" FontSize="9" Foreground="#999999" HorizontalAlignment="Center" FontStyle="Italic" />
                </StackPanel>
            </Border>
        </ScrollViewer>
        <Border Grid.Row="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0" Padding="15,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnExportPdf" Style="{DynamicResource SecondaryBtn}" Height="36" Click="BtnExportPdf_Click">
                    <TextBlock Text="Export PDF" VerticalAlignment="Center" />
                </Button>
                <Button x:Name="BtnPrint" Style="{DynamicResource PrimaryBtn}" Height="36" Margin="10,0,0,0" Click="BtnPrint_Click" IsDefault="True">
                    <TextBlock Text="Print" VerticalAlignment="Center" />
                </Button>
                <Button x:Name="BtnClose" Style="{DynamicResource SecondaryBtn}" Height="36" Margin="10,0,0,0" Click="BtnClose_Click" IsCancel="True">
                    <TextBlock Text="Close" VerticalAlignment="Center" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
