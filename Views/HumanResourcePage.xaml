<UserControl x:Class="MortuaryApp.Views.HumanResourcePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBgBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" x:Name="FormCard" Style="{DynamicResource Card}" Margin="0,0,0,15" Visibility="Collapsed">
            <StackPanel>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="TxtFormTitle" Text="New User" Style="{StaticResource ModernSectionTitle}" />
                    <Button Grid.Column="1" x:Name="BtnCancelForm" MinWidth="80" Height="30" Style="{DynamicResource SecondaryBtn}" Click="BtnCancelForm_Click">
                        <TextBlock Text="Cancel" />
                    </Button>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Full Name" Style="{StaticResource ModernFormLabel}" />
                        <TextBox x:Name="TxtFullName" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernTextBox}" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Username" Style="{StaticResource ModernFormLabel}" />
                        <TextBox x:Name="TxtUsername" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernTextBox}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Email" Style="{StaticResource ModernFormLabel}" />
                        <TextBox x:Name="TxtEmail" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernTextBox}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="Password" Style="{StaticResource ModernFormLabel}" />
                        <PasswordBox x:Name="TxtPassword" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernPasswordBox}" />
                    </StackPanel>
                </Grid>
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Confirm Password" Style="{StaticResource ModernFormLabel}" />
                        <PasswordBox x:Name="TxtConfirmPassword" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernPasswordBox}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Role" Style="{StaticResource ModernFormLabel}" />
                        <ComboBox x:Name="CboRole" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernComboBox}" DisplayMemberPath="Name"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Margin="0,0,0,4">
                        <CheckBox x:Name="ChkIsActive" Content="Active" IsChecked="True" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                </Grid>
                <Button x:Name="BtnSaveUser" MinWidth="120" Height="34" Margin="0,14,0,0" HorizontalAlignment="Right" Style="{DynamicResource PrimaryBtn}" Click="BtnSaveUser_Click">
                    <TextBlock Text="Save User" VerticalAlignment="Center" />
                </Button>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnShowForm" MinWidth="100" Height="34" Style="{DynamicResource PrimaryBtn}" Margin="0,0,10,0" Click="BtnShowForm_Click">
                    <TextBlock Text="+ New User" VerticalAlignment="Center" />
                </Button>
            </StackPanel>
            <DataGrid Grid.Row="1" x:Name="DgUsers" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*" />
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="100" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150" />
                    <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="70" />
                    <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="60" />
                    <DataGridTemplateColumn Header="Actions" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Name="BtnEditUser" Content="Edit" MinWidth="50" Height="28" FontSize="11" Style="{DynamicResource SecondaryBtn}" Margin="0,0,6,0"
                                            CommandParameter="{Binding Id}" Click="BtnEditUser_Click" />
                                    <Button Name="BtnResetPassword" Content="Reset Pwd" MinWidth="60" Height="28" FontSize="11" Style="{DynamicResource SecondaryBtn}"
                                            CommandParameter="{Binding Id}" Click="BtnResetPassword_Click" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
