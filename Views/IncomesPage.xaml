<UserControl x:Class="MortuaryApp.Views.IncomesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBgBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{DynamicResource Card}" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Record Income" Style="{DynamicResource SectionHeader}" Margin="0,0,0,10" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Name" Style="{StaticResource ModernFormLabel}" />
                        <TextBox x:Name="TxtName" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernTextBox}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Amount (₵)" Style="{StaticResource ModernFormLabel}" />
                        <TextBox x:Name="TxtAmount" Text="0" Height="34" Margin="0,4,0,0" Style="{DynamicResource ModernTextBox}" />
                    </StackPanel>
                    <Button Grid.Column="3" x:Name="BtnAdd" Height="34" Margin="10,22,0,0" Style="{DynamicResource PrimaryBtn}" Click="BtnAdd_Click">
                        <TextBlock Text="+ Add Income" VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
        <DataGrid Grid.Row="1" x:Name="DgIncomes" IsReadOnly="True" AutoGenerateColumns="False" Style="{DynamicResource ModernDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="120" />
                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
