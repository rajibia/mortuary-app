<Window x:Class="MortuaryApp.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password" Height="280" Width="380"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow"
        ResizeMode="NoResize" FontFamily="Segoe UI"
        Background="#FFFFFF" Foreground="#0F172A">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="You must change your password before continuing." FontSize="13" Foreground="#DC2626" TextWrapping="Wrap" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Text="New Password" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
        <Border Grid.Row="2" BorderThickness="1" BorderBrush="#D1D5DB" Background="#F9FAFB" Height="42">
            <PasswordBox x:Name="TxtNewPassword" Background="Transparent" BorderThickness="0"
                         FontSize="13" Foreground="#0F172A" VerticalAlignment="Center" Margin="12,0"/>
        </Border>

        <TextBlock Grid.Row="3" Text="Confirm Password" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,14,0,6"/>
        <Border Grid.Row="4" BorderThickness="1" BorderBrush="#D1D5DB" Background="#F9FAFB" Height="42">
            <PasswordBox x:Name="TxtConfirmPassword" Background="Transparent" BorderThickness="0"
                         FontSize="13" Foreground="#0F172A" VerticalAlignment="Center" Margin="12,0"/>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnSave" Content="Change Password" Height="38" Click="BtnSave_Click" IsDefault="True" Style="{StaticResource PrimaryBtn}" Padding="20,0"/>
            <Button x:Name="BtnCancel" Content="Cancel" Width="80" Height="38" Margin="10,0,0,0" Click="BtnCancel_Click" IsCancel="True" Style="{StaticResource SecondaryBtn}"/>
        </StackPanel>
    </Grid>
</Window>
